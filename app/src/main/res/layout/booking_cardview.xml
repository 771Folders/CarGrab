<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="12dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/passengerName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Passenger Name: "
            style="?attr/textAppearanceTitleMedium"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pickup:" />

                <TextView
                    android:id="@+id/pickupLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="242 Rillo St. Tuy, Batangas" />

            </LinearLayout>

            <LinearLayout
                android:layout_marginLeft="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Destination:" />

                <TextView
                    android:id="@+id/destinationLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Donya Salome Subd. Malaruhatan, Lian, Batangas" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fare:" />

                <TextView
                    android:id="@+id/estimatedFare"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PHP 100.00" />

            </LinearLayout>

            <LinearLayout
                android:layout_marginLeft="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Time:" />

                <TextView
                    android:id="@+id/estimatedTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="30mins" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/acceptButton"
                    android:layout_width="200dp"
                    android:layout_height="50dp"
                    android:text="Accept"
                    app:cornerRadius="8dp"
                    android:backgroundTint="@color/black"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/ignoreButton"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    app:cornerRadius="8dp"
                    android:text="Ignore"
                    app:strokeColor="@color/black"
                    style="@style/Widget.Material3.Button.IconButton.Outlined"/>

            </com.google.android.material.button.MaterialButtonToggleGroup>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>